generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Track {
  id              String           @id @default(uuid())
  filePath        String
  fileName        String
  title           String
  artist          String
  album           String
  bpm             Int?
  durationMs      Int
  coverImagePath  String?
  isFallback      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  playlistEntries PlaylistTrack[]
  padSlots        PadSlot[]
  markers         TrackMarker[]

  @@unique([filePath])
  @@index([title])
  @@index([artist])
}

model TrackMarker {
  id        String   @id @default(uuid())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  position  Float
  label     String
  createdAt DateTime @default(now())

  @@index([trackId])
}

model Playlist {
  id          String          @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tracks      PlaylistTrack[]
}

model PlaylistTrack {
  id         String   @id @default(uuid())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId String
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId    String
  order      Int

  @@unique([playlistId, trackId])
  @@index([playlistId, order])
}

model PadLayout {
  id          String    @id @default(uuid())
  name        String
  rows        Int
  cols        Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  slots       PadSlot[]
  cases       Case[]    @relation("CaseActiveLayout")
}

model PadSlot {
  id          String    @id @default(uuid())
  padLayout   PadLayout @relation(fields: [padLayoutId], references: [id], onDelete: Cascade)
  padLayoutId String
  row         Int
  col         Int
  track       Track?    @relation(fields: [trackId], references: [id])
  trackId     String?
  color       String
  label       String

  @@unique([padLayoutId, row, col])
}

model Case {
  id                String     @id @default(uuid())
  name              String
  description       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  activePadLayout   PadLayout? @relation("CaseActiveLayout", fields: [activePadLayoutId], references: [id])
  activePadLayoutId String?
}

